def sumCounts(nums):
    n = len(nums)
    result = 0 
    for i in range(n):
        seen = set()
        for j in range(i, n):
            seen.add(nums[j])
            distinct_count = len(seen)
            result += distinct_count ** 2
    return result 
nums = [1, 2, 1]
print(sumCounts(nums))  
