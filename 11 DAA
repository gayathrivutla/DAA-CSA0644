def paths(m,n,N,i,j):
    dp={(i,j):1}; c=0
    for _ in range(N):
        nd={}
        for (x,y),v in dp.items():
            for dx,dy in [(1,0),(-1,0),(0,1),(0,-1)]:
                nx,ny=x+dx,y+dy
                if nx<0 or ny<0 or nx>=m or ny>=n:
                    c+=v
                else:
                    nd[(nx,ny)]=nd.get((nx,ny),0)+v
        dp=nd
    return c

print("Output:", paths(2,2,2,0,0))
print("Output:", paths(1,3,3,0,1))
