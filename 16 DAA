def champ(p,r,g):
    dp=[[0]*101 for _ in range(101)]
    dp[0][0]=p
    for i in range(r+1):
        for j in range(i+1):
            x=max(0,(dp[i][j]-1)/2)
            dp[i+1][j]+=x
            dp[i+1][j+1]+=x
    return min(1,dp[r][g])

print("Output:", champ(1,1,1))
print("Output:", champ(2,1,1))
