def kth_missing(arr, k):
    current = 1
    i = 0
    while True:
        if i < len(arr) and arr[i] == current:
            i += 1
        else:
            k -= 1
            if k == 0:
                return current
        current += 1

# Test
print(kth_missing([2,3,4,7,11],5))
print(kth_missing([1,2,3,4],2))
